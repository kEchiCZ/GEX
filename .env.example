# GEXLens — příklad konfigurace enginu.
# Zkopíruj jako `.env` a uprav. Všechny položky mají defaulty (viz engine/src/gexlens_engine/config.py);
# stačí nastavit jen to, co měníš. `.env` je v .gitignore — nikdy ho necommituj.

# ── IBKR připojení (SPEC 3.1) ────────────────────────────────────
GEXLENS_IBKR_HOST=127.0.0.1
# 7496 = TWS live, 7497 = TWS paper, 4001/4002 = IB Gateway defaulty
GEXLENS_IBKR_PORT=7496
GEXLENS_IBKR_CLIENT_ID=1
# 1 = live; delayed data engine odmítá (Greeks z nich nejsou spolehlivé)
GEXLENS_MARKET_DATA_TYPE=1
# Timeout connectu [s] a exponenciální backoff reconnectu (SPEC 3.1: 2 → 60 s)
GEXLENS_CONNECT_TIMEOUT_S=10
GEXLENS_RECONNECT_BACKOFF_BASE_S=2
GEXLENS_RECONNECT_BACKOFF_MAX_S=60

# ── Instrumenty (ADR-0003) ──────────────────────────────────────
# Základní sada futures podkladů (čárkami oddělený seznam); watchlist z UI se přidává za běhu
GEXLENS_SYMBOLS=ES
# Strop souběžně běžících instrumentů (rozpočet market data lines)
GEXLENS_MAX_INSTRUMENTS=3
# Watchlist z DB se čte každý k-tý minutový cyklus
GEXLENS_WATCHLIST_POLL_CYCLES=5
# Ranní OI archiv pokrývá N nejbližších expirací (ΔOI vs. včera)
GEXLENS_OI_ARCHIVE_EXPIRIES=5
# Sweep následující expirace (positioning příští seance) v kadenci každý k-tý cyklus
GEXLENS_SWEEP_NEXT_EXPIRY=true
GEXLENS_NEXT_EXPIRY_SWEEP_EVERY=3
# Setup detektor (ADR-0004): analýzy s auto-vyhodnocováním; ukládá do PG tabulky setups
GEXLENS_SETUPS_ENABLED=true
# Minimální dominance zdi pro šablony T1/T3 (ADR-0010; podíl zdi na síle strany, 0–1)
GEXLENS_SETUP_MIN_WALL_DOMINANCE=0.15
# Flow-adjusted OI odhad (ADR-0011): OI_est = ranní OI + α·čistý klasifikovaný objem;
# α z validace open-ratio (~0,39 na čistém dni), 0 = vrstva vypnutá
GEXLENS_FLOW_OI_ALPHA=0.4

# ── Opční řetězec a scheduler (SPEC 3.2, 3.3) ────────────────────
# Výchozí denní obálka strikes: spot ±X bodů (reset na session start)
GEXLENS_STRIKE_RANGE_POINTS=200
# Auto-rozšíření obálky při přiblížení spotu k okraji na < 25 % šířky (grow-only, ADR-0002)
GEXLENS_STRIKE_RANGE_EXPAND_THRESHOLD=0.25
# Strop šířky obálky; při dosažení se obálka posouvá za spotem (alert)
GEXLENS_STRIKE_RANGE_MAX_POINTS=800
# Velikost rotační dávky subskripcí
GEXLENS_BATCH_SIZE=80
# Timeout čekání na kompletní data dávky [s]
GEXLENS_BATCH_TIMEOUT_S=4
# Křídla řetězce se sweepují každý k-tý cyklus; ATM±šířka každý cyklus
GEXLENS_WINGS_SWEEP_EVERY=3
GEXLENS_ATM_SWEEP_WIDTH=30
# Max pokusů repair fronty na kontrakt za sweep
GEXLENS_REPAIR_MAX_ATTEMPTS=3
# Kapacita market data lines účtu (ADR-0001: naměřeno >= 150)
GEXLENS_MARKET_DATA_LINES=100

# Tichá ztráta 5s barů (#221): alert po N minutách bez baru při živém spotu
GEXLENS_BARS_STALL_ALERT_MINUTES=3

# ── Hot zóna (SPEC 3.4; limity účtu viz docs/adr/0001) ──────────
# Cílová šířka hot zóny: ATM ± N strikes
GEXLENS_HOT_ZONE_WIDTH=15
# Max souběžných tick-by-tick streamů (naměřený limit účtu = 5)
GEXLENS_TICK_BY_TICK_MAX_STREAMS=5

# ── Storage a retence (SPEC kap. 5) ─────────────────────────────
# PostgreSQL (OI archiv + metadata); default sedí na docker compose dev instanci
GEXLENS_DATABASE_URL=postgresql+psycopg://gexlens:gexlens@localhost:5432/gexlens
GEXLENS_DATA_DIR=data
GEXLENS_RETENTION_DAYS=14
GEXLENS_DISK_LIMIT_GB=2
# Čas nočního purge jobu (UTC, po zavření US seance)
GEXLENS_RETENTION_PURGE_TIME_UTC=21:30

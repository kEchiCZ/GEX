# GEXLens — příklad konfigurace enginu.
# Zkopíruj jako `.env` a uprav. Všechny položky mají defaulty (viz engine/src/gexlens_engine/config.py);
# stačí nastavit jen to, co měníš. `.env` je v .gitignore — nikdy ho necommituj.

# ── IBKR připojení (SPEC 3.1) ────────────────────────────────────
GEXLENS_IBKR_HOST=127.0.0.1
# 7496 = TWS live, 7497 = TWS paper, 4001/4002 = IB Gateway defaulty
GEXLENS_IBKR_PORT=7496
GEXLENS_IBKR_CLIENT_ID=1
# 1 = live; delayed data engine odmítá (Greeks z nich nejsou spolehlivé)
GEXLENS_MARKET_DATA_TYPE=1
# Timeout connectu [s] a exponenciální backoff reconnectu (SPEC 3.1: 2 → 60 s)
GEXLENS_CONNECT_TIMEOUT_S=10
GEXLENS_RECONNECT_BACKOFF_BASE_S=2
GEXLENS_RECONNECT_BACKOFF_MAX_S=60

# ── Opční řetězec a scheduler (SPEC 3.2, 3.3) ────────────────────
# Pásmo strikes ±X bodů od spotu
GEXLENS_STRIKE_RANGE_POINTS=200
# Auto-rozšíření pásma při přiblížení spotu k okraji na < 25 % šířky
GEXLENS_STRIKE_RANGE_EXPAND_THRESHOLD=0.25
# Velikost rotační dávky subskripcí
GEXLENS_BATCH_SIZE=80
# Timeout čekání na kompletní data dávky [s]
GEXLENS_BATCH_TIMEOUT_S=4
# Křídla řetězce se sweepují každý k-tý cyklus; ATM±šířka každý cyklus
GEXLENS_WINGS_SWEEP_EVERY=3
GEXLENS_ATM_SWEEP_WIDTH=30
# Max pokusů repair fronty na kontrakt za sweep
GEXLENS_REPAIR_MAX_ATTEMPTS=3
# Kapacita market data lines účtu (ADR-0001: naměřeno >= 150)
GEXLENS_MARKET_DATA_LINES=100

# ── Hot zóna (SPEC 3.4; limity účtu viz docs/adr/0001) ──────────
# Cílová šířka hot zóny: ATM ± N strikes
GEXLENS_HOT_ZONE_WIDTH=15
# Max souběžných tick-by-tick streamů (naměřený limit účtu = 5)
GEXLENS_TICK_BY_TICK_MAX_STREAMS=5

# ── Storage a retence (SPEC kap. 5) ─────────────────────────────
GEXLENS_DATA_DIR=data
GEXLENS_RETENTION_DAYS=14
GEXLENS_DISK_LIMIT_GB=2
